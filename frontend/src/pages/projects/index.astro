---
import BaseLayout from '@/layouts/BaseLayout.astro'
import RichText from '@/components/RichText.astro'
import Card from '@/components/ui/Card.astro'
import Container from '@/components/layout/Container.astro'
import {
  baseLanguage,
  defaultLocale,
  languageQueryParams,
  localePath,
  normalizeLocale,
} from '@/lib/i18n'
import { sanity } from '@/lib/sanity'
import { projectsIndexQuery, projectsPageQuery } from '@/lib/sanityQueries'
import { urlForImage } from '@/lib/sanityImage'

const { locale: localeProp } = Astro.props as { locale?: string }
const locale = normalizeLocale(localeProp ?? defaultLocale)
const localeParams = languageQueryParams(locale)
const fallbackParams = languageQueryParams(baseLanguage)

const projectsPage = sanity
  ? ((await sanity.fetch<any>(projectsPageQuery, localeParams)) ??
    (locale === baseLanguage ? null : await sanity.fetch<any>(projectsPageQuery, fallbackParams)))
  : null

const localizedProjects = sanity ? await sanity.fetch<any[]>(projectsIndexQuery, localeParams) : []
const fallbackProjects =
  sanity && locale !== baseLanguage
    ? await sanity.fetch<any[]>(projectsIndexQuery, fallbackParams)
    : []
const projects =
  Array.isArray(localizedProjects) && localizedProjects.length
    ? localizedProjects
    : fallbackProjects

const projectTypeLabel: Record<string, string> = {
  documentary: 'Documentary',
  shortFilm: 'Short film',
  article: 'Article',
  socialMedia: 'Social media',
}
---

<BaseLayout title={projectsPage?.seo?.metaTitle || projectsPage?.title} locale={locale}>
  <Container size="wide" class="space-y-8">
    <header class="space-y-3">
      {projectsPage?.title ? <h1 class="text-4xl tracking-tight">{projectsPage.title}</h1> : null}
      {
        projectsPage?.intro ? (
          <section class="max-w-3xl">
            <RichText value={projectsPage.intro} />
          </section>
        ) : null
      }
    </header>

    <div class="grid gap-4">
      {
        projects.length ? (
          <>
            {projects.map((p) => (
              <Card
                as="article"
                tone="surface"
                class="group flex items-stretch justify-between gap-4"
              >
                <a
                  href={localePath(`/projects/${p.slug}`, locale)}
                  class="min-w-0 flex-1 self-stretch rounded-(--site-radius-input) transition-colors hover:text-interactive focus-visible:outline-2 focus-visible:outline-focus-ring focus-visible:outline-offset-2"
                >
                  <h2 class="text-xl tracking-tight">{p.title}</h2>
                  <p class="mt-2 text-sm text-muted">{p.year ? p.year : '-'}</p>
                  {Array.isArray(p.projectTypes) && p.projectTypes.length ? (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {p.projectTypes.map((type: string) => (
                        <span class="inline-flex items-center rounded-(--site-radius-badge) border border-border bg-background px-2.5 py-1 text-xs text-muted">
                          {projectTypeLabel[type] || type}
                        </span>
                      ))}
                    </div>
                  ) : null}
                </a>
                <div class="h-16 w-24 shrink-0 overflow-hidden rounded-md border border-border bg-background">
                  {p.hero?.image ? (
                    <img
                      src={urlForImage(p.hero.image)
                        ?.width(360)
                        .height(240)
                        .fit('crop')
                        .auto('format')
                        .url()}
                      alt={p.hero?.alt || p.title || ''}
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-105 motion-reduce:transition-none motion-reduce:group-hover:scale-100"
                    />
                  ) : (
                    <div class="h-full w-full" aria-hidden="true" />
                  )}
                </div>
              </Card>
            ))}
          </>
        ) : null
      }
    </div>
  </Container>
</BaseLayout>
