---
import BaseLayout from '@/layouts/BaseLayout.astro'
import RichText from '@/components/RichText.astro'
import Card from '@/components/ui/Card.astro'
import Container from '@/components/layout/Container.astro'
import {
  baseLanguage,
  defaultLocale,
  languageQueryParams,
  localePath,
  normalizeLocale,
} from '@/lib/i18n'
import { sanity } from '@/lib/sanity'
import { allProjectSlugsQuery, projectBySlugQuery } from '@/lib/sanityQueries'
import { urlForImage } from '@/lib/sanityImage'

export async function getStaticPaths() {
  if (!sanity) return []

  const localeParams = languageQueryParams(defaultLocale)
  const fallbackParams = languageQueryParams(baseLanguage)

  const localizedProjects = await sanity.fetch<{ slug: string }[]>(
    allProjectSlugsQuery,
    localeParams,
  )
  const fallbackProjects =
    defaultLocale === baseLanguage
      ? []
      : ((await sanity.fetch<{ slug: string }[]>(allProjectSlugsQuery, fallbackParams)) ?? [])
  const projects =
    Array.isArray(localizedProjects) && localizedProjects.length
      ? localizedProjects
      : fallbackProjects

  return projects.map((p) => ({ params: { slug: p.slug } }))
}

const { locale: localeProp } = Astro.props as { locale?: string }
const locale = normalizeLocale(localeProp ?? defaultLocale)
const localeParams = languageQueryParams(locale)
const fallbackParams = languageQueryParams(baseLanguage)

const { slug } = Astro.params
const project = sanity
  ? ((await sanity.fetch<any>(projectBySlugQuery, { ...localeParams, slug })) ??
    (locale === baseLanguage
      ? null
      : await sanity.fetch<any>(projectBySlugQuery, { ...fallbackParams, slug })))
  : null

const projectTypeLabel: Record<string, string> = {
  documentary: 'Documentary',
  shortFilm: 'Short film',
  article: 'Article',
  socialMedia: 'Social media',
}

const heroUrl =
  project?.hero?.image &&
  urlForImage(project.hero.image)?.width(2000).fit('max').auto('format').url()
---

<BaseLayout title={project?.title || slug} locale={locale}>
  <Container size="wide" class="space-y-8">
    <header class="space-y-3">
      <div>
        <a href={localePath('/projects', locale)}>Back to projects</a>
      </div>
      <h1 class="text-4xl tracking-tight">{project?.title || slug}</h1>
      {project?.year ? <p class="text-muted">{project.year}</p> : null}
      {
        Array.isArray(project?.projectTypes) && project.projectTypes.length ? (
          <div class="flex flex-wrap gap-2 pt-1">
            {project.projectTypes.map((type: string) => (
              <span class="inline-flex items-center rounded-(--site-radius-badge) border border-border bg-surface px-3 py-1 text-xs text-muted">
                {projectTypeLabel[type] || type}
              </span>
            ))}
          </div>
        ) : null
      }
    </header>
    {
      heroUrl ? (
        <section class="pt-6">
          <img
            src={heroUrl}
            alt={project?.hero?.alt || ''}
            loading="lazy"
            class="aspect-video w-full object-cover"
          />
        </section>
      ) : null
    }
    {
      project?.body ? (
        <section>
          <Card tone="surface">
            <RichText value={project.body} />
          </Card>
        </section>
      ) : null
    }
  </Container>
</BaseLayout>
